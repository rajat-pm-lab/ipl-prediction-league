{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/config",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/leaderboard/(.*)",
      "dest": "/api/routes/leaderboard.js"
    },
    {
      "src": "/api/player/(.*)",
      "dest": "/api/routes/player.js"
    },
    {
      "src": "/api/matches/(.*)",
      "dest": "/api/routes/matches.js"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/routes/admin.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/routes/auth.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
